<div id="survey_<%= message.id %>"
     data-controller="survey"
     class="opacity-0 transition-opacity duration-700 ease-in-out mb-6 p-6 rounded-2xl bg-warm-bg/60 border border-primary/10">
  <%= form_with model: message, url: survey_message_path(message), method: :patch, data: { survey_target: "form" } do |f| %>
    <p class="text-center text-main-text font-bold mb-4">このメッセージの出来はいかがですか？</p>

    <%# Q1: 満足度 %>
    <div class="flex justify-center gap-3 mb-4">
      <% [
        [1, "😞"],
        [2, "😕"],
        [3, "😐"],
        [4, "🙂"],
        [5, "😄"]
      ].each do |value, emoji| %>
        <label class="cursor-pointer" data-survey-target="ratingLabel" data-action="click->survey#selectRating">
          <%= f.radio_button :satisfaction_rating, value, class: "hidden", data: { survey_target: "ratingInput" } %>
          <span class="text-3xl inline-block transition-all duration-200 hover:scale-125 opacity-60 hover:opacity-100"
                data-survey-target="ratingEmoji"><%= emoji %></span>
        </label>
      <% end %>
    </div>

    <%# Q2: 使い道（Q1選択後に表示） %>
    <div data-survey-target="purposeSection" class="hidden">
      <p class="text-center text-sub-text text-sm mb-3">このメッセージをどう使いますか？（任意）</p>
      <div class="grid grid-cols-2 gap-2 mb-4">
        <% [
          ["send_as_is", "そのまま送る"],
          ["edit_and_send", "編集して送る"],
          ["reference", "参考にする"],
          ["just_tried", "試しに使った"]
        ].each do |value, label| %>
          <label class="cursor-pointer" data-action="click->survey#selectPurpose">
            <%= f.radio_button :usage_purpose, value, class: "hidden", data: { survey_target: "purposeInput" } %>
            <span class="block text-center py-2 px-3 rounded-lg border border-primary/15 text-sm text-sub-text hover:border-primary/40 hover:text-primary transition-all"
                  data-survey-target="purposeLabel"><%= label %></span>
          </label>
        <% end %>
      </div>
    </div>

    <%# 送信・スキップボタン（Q1選択後に表示） %>
    <div data-survey-target="actions" class="hidden flex justify-center gap-3">
      <%= f.submit "回答する", class: "px-6 py-2 bg-primary text-white rounded-lg text-sm font-bold hover:shadow-md transition-all cursor-pointer" %>
      <button type="submit" data-action="click->survey#skip" class="px-6 py-2 text-sub-text text-sm hover:text-primary transition-all cursor-pointer">
        スキップ
      </button>
    </div>
  <% end %>
</div>
