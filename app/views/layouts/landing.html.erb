<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= meta_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= meta_description %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# OGP メタタグ %>
    <meta property="og:title" content="<%= meta_title %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= meta_url %>">
    <meta property="og:image" content="<%= meta_image %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="Epistory">
    <meta property="og:locale" content="ja_JP">

    <%# Twitter Card メタタグ %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= meta_title %>">
    <meta name="twitter:description" content="<%= meta_description %>">
    <meta name="twitter:image" content="<%= meta_image %>">

    <link href="https://fonts.googleapis.com/css2?family=Klee+One:wght@600&family=Zen+Maru+Gothic:wght@300;400;500&family=Yomogi&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <% if Rails.env.production? %>
      <!-- Google tag (gtag.js) -->
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-PD9S60DQ6K"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-PD9S60DQ6K');
      </script>
    <% end %>
  </head>

  <body class="bg-[#faf6f0] text-[#3d3229]" style="font-family: 'Zen Maru Gothic', sans-serif; line-height: 1.8;">
    <div <%= "data-controller=sidebar" if logged_in? %>>
    <%# LP専用ミニマルヘッダー %>
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#faf6f0]/90 backdrop-blur-sm border-b border-[#b07d6a]/10">
      <div class="mx-auto max-w-5xl flex items-center justify-between px-4 py-3">
        <div class="flex items-center gap-2">
          <% if logged_in? %>
            <button data-action="click->sidebar#toggle" class="p-1.5 rounded-lg hover:bg-[#b07d6a]/10 transition-colors" aria-label="メッセージ履歴">
              <span class="material-symbols-outlined text-[#b07d6a] text-2xl">menu</span>
            </button>
          <% end %>
          <a href="<%= root_path %>" class="text-xl font-medium text-[#3d3229] tracking-wide" style="font-family: 'Klee One', cursive;">
            Epistory
          </a>
        </div>
        <div class="flex items-center gap-3">
          <% if logged_in? %>
            <%= button_to "ログアウト", logout_path, method: :delete, class: "text-sm font-medium text-[#6b5e52] hover:text-[#b07d6a] transition-colors" %>
          <% else %>
            <a href="<%= login_path %>" class="text-sm font-medium text-[#6b5e52] hover:text-[#b07d6a] transition-colors">ログイン</a>
          <% end %>
          <a href="<%= step1_message_path %>"
             class="inline-block rounded-full bg-[#b07d6a] px-5 py-2 text-sm font-medium text-white transition hover:bg-[#966552] hover:shadow-md">
            メッセージを作る
          </a>
        </div>
      </div>
    </header>

    <%= render "shared/sidebar" %>

    <main>
      <%= yield %>
    </main>

    </div>
    <%# LP専用フッター %>
    <footer class="border-t border-[#b07d6a]/10 bg-[#f0ebe2] py-8">
      <div class="mx-auto max-w-5xl px-4 text-center text-sm text-[#6b5e52]">
        <div class="mb-4 flex items-center justify-center gap-6">
          <a href="<%= terms_path %>" class="hover:text-[#b07d6a] transition">利用規約</a>
          <a href="<%= privacy_path %>" class="hover:text-[#b07d6a] transition">プライバシーポリシー</a>
          <a href="<%= contact_path %>" class="hover:text-[#b07d6a] transition">お問い合わせ</a>
        </div>
        <p>&copy; <%= Date.current.year %> Epistory</p>
      </div>
    </footer>
  </body>
</html>
