<% if logged_in? %>
  <%# デスクトップ: 固定サイドバー %>
  <aside class="hidden md:flex flex-col w-72 flex-shrink-0 border-r border-primary/10 bg-white/50 h-[calc(100vh-65px)] sticky top-[65px] overflow-y-auto">
    <div class="p-4 border-b border-primary/10">
      <h2 class="text-sm font-bold text-main-text flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-lg">history</span>
        メッセージ履歴
      </h2>
    </div>

    <% if @sidebar_messages.present? %>
      <nav class="flex-1 overflow-y-auto">
        <ul class="divide-y divide-primary/5">
          <% @sidebar_messages.each do |message| %>
            <li class="group relative">
              <%= link_to message_path(message), class: "block px-4 py-3 hover:bg-primary/5 transition-colors" do %>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-medium text-primary"><%= message.recipient.name %></span>
                  <span class="text-xs text-sub-text/60"><%= message.created_at.strftime("%-m/%-d") %></span>
                </div>
                <p class="text-sm text-main-text truncate"><%= truncate(message.edited_content.presence || message.generated_content, length: 30) %></p>
              <% end %>
              <%= button_to message_path(message), method: :delete,
                    class: "absolute right-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 p-1 rounded-full hover:bg-red-50 text-sub-text/40 hover:text-red-500 transition-all",
                    data: { turbo_confirm: "このメッセージを削除しますか？" } do %>
                <span class="material-symbols-outlined text-base">delete</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </nav>

      <% if @sidebar_messages.total_pages > 1 %>
        <div class="p-3 border-t border-primary/10 flex items-center justify-center gap-2 text-xs">
          <% if @sidebar_messages.prev_page %>
            <%= link_to "前へ", url_for(sidebar_page: @sidebar_messages.prev_page), class: "text-primary hover:underline" %>
          <% end %>
          <span class="text-sub-text"><%= @sidebar_messages.current_page %> / <%= @sidebar_messages.total_pages %></span>
          <% if @sidebar_messages.next_page %>
            <%= link_to "次へ", url_for(sidebar_page: @sidebar_messages.next_page), class: "text-primary hover:underline" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="flex-1 flex flex-col items-center justify-center p-6 text-center">
        <span class="material-symbols-outlined text-4xl text-sub-text/30 mb-3">mail</span>
        <p class="text-sm text-sub-text/60 mb-4">まだメッセージがありません</p>
        <%= link_to "メッセージを作る", new_message_path, class: "text-sm font-medium text-primary hover:underline" %>
      </div>
    <% end %>
  </aside>

  <%# モバイル: スライドインドロワー %>
  <div data-controller="sidebar" class="md:hidden">
    <%# オーバーレイ %>
    <div data-sidebar-target="overlay"
         data-action="click->sidebar#close"
         class="fixed inset-0 z-40 bg-black/30 backdrop-blur-sm hidden transition-opacity"></div>

    <%# ドロワー本体 %>
    <aside data-sidebar-target="drawer"
           class="fixed top-0 left-0 z-50 h-full w-72 bg-white shadow-xl -translate-x-full transition-transform duration-300 ease-in-out">
      <div class="flex items-center justify-between p-4 border-b border-primary/10">
        <h2 class="text-sm font-bold text-main-text flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-lg">history</span>
          メッセージ履歴
        </h2>
        <button data-action="click->sidebar#close" class="p-1 rounded-full hover:bg-primary/5 text-sub-text">
          <span class="material-symbols-outlined text-xl">close</span>
        </button>
      </div>

      <% if @sidebar_messages.present? %>
        <nav class="flex-1 overflow-y-auto" style="max-height: calc(100vh - 65px);">
          <ul class="divide-y divide-primary/5">
            <% @sidebar_messages.each do |message| %>
              <li class="relative">
                <%= link_to message_path(message), class: "block px-4 py-3 hover:bg-primary/5 transition-colors" do %>
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs font-medium text-primary"><%= message.recipient.name %></span>
                    <span class="text-xs text-sub-text/60"><%= message.created_at.strftime("%-m/%-d") %></span>
                  </div>
                  <p class="text-sm text-main-text truncate"><%= truncate(message.edited_content.presence || message.generated_content, length: 30) %></p>
                <% end %>
                <%= button_to message_path(message), method: :delete,
                      class: "absolute right-2 top-1/2 -translate-y-1/2 p-1 rounded-full hover:bg-red-50 text-sub-text/40 hover:text-red-500 transition-all",
                      data: { turbo_confirm: "このメッセージを削除しますか？" } do %>
                  <span class="material-symbols-outlined text-base">delete</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </nav>

        <% if @sidebar_messages.total_pages > 1 %>
          <div class="p-3 border-t border-primary/10 flex items-center justify-center gap-2 text-xs">
            <% if @sidebar_messages.prev_page %>
              <%= link_to "前へ", url_for(sidebar_page: @sidebar_messages.prev_page), class: "text-primary hover:underline" %>
            <% end %>
            <span class="text-sub-text"><%= @sidebar_messages.current_page %> / <%= @sidebar_messages.total_pages %></span>
            <% if @sidebar_messages.next_page %>
              <%= link_to "次へ", url_for(sidebar_page: @sidebar_messages.next_page), class: "text-primary hover:underline" %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="flex-1 flex flex-col items-center justify-center p-6 text-center" style="min-height: 200px;">
          <span class="material-symbols-outlined text-4xl text-sub-text/30 mb-3">mail</span>
          <p class="text-sm text-sub-text/60 mb-4">まだメッセージがありません</p>
          <%= link_to "メッセージを作る", new_message_path, class: "text-sm font-medium text-primary hover:underline" %>
        </div>
      <% end %>
    </aside>
  </div>
<% end %>
